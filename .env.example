# ============================================================
# BillKaro — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:3000

# ── Database (PostgreSQL)ass ───────────────────────────────────
DATABASE_URL=postgresql://billkaro:billkaro_dev@localhost:5432/billkaro_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# ── Meta WhatsApp Cloud API ─────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-webhook-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_API_VERSION=v21.0

# ── OpenAI (NLU + Whisper) ──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_NLU_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# ── Payment (Zero MDR — Direct UPI) ─────────────────────────
# No payment gateway needed! Merchants receive money directly
# via UPI/Bank Transfer. UPI ID and bank details are collected
# during onboarding and embedded in invoices with QR codes.

# ── File Storage (Cloudflare R2 / AWS S3) ───────────────────
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=billkaro-invoices
S3_ACCESS_KEY=your-r2-access-key
S3_SECRET_KEY=your-r2-secret-key
S3_REGION=auto
S3_PUBLIC_URL=https://invoices.billkaro.in

# ── Invoice Defaults ────────────────────────────────────────
DEFAULT_GST_RATE=18
DEFAULT_PAYMENT_TERMS_DAYS=7
INVOICE_PREFIX=BK
