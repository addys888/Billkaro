<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      font-size: 13px;
      color: #1a1a1a;
      line-height: 1.5;
    }
    .invoice-container {
      max-width: 210mm;
      margin: 0 auto;
      padding: 20px;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 3px solid #2563eb;
      padding-bottom: 16px;
      margin-bottom: 24px;
    }
    .brand h1 {
      font-size: 28px;
      color: #2563eb;
      font-weight: 800;
      letter-spacing: -0.5px;
    }
    .brand p {
      color: #6b7280;
      font-size: 12px;
      margin-top: 2px;
    }
    .invoice-title {
      text-align: right;
    }
    .invoice-title h2 {
      font-size: 22px;
      color: #1a1a1a;
      text-transform: uppercase;
      letter-spacing: 2px;
    }
    .invoice-title .invoice-no {
      font-size: 14px;
      color: #2563eb;
      font-weight: 600;
      margin-top: 4px;
    }
    .invoice-title .date {
      font-size: 12px;
      color: #6b7280;
      margin-top: 2px;
    }
    .parties {
      display: flex;
      justify-content: space-between;
      margin-bottom: 24px;
      gap: 40px;
    }
    .party {
      flex: 1;
    }
    .party-label {
      font-size: 11px;
      color: #9ca3af;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6px;
      font-weight: 600;
    }
    .party-name {
      font-size: 16px;
      font-weight: 700;
      color: #1a1a1a;
    }
    .party-detail {
      font-size: 12px;
      color: #4b5563;
      margin-top: 2px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 24px;
    }
    thead th {
      background: #f3f4f6;
      padding: 10px 12px;
      text-align: left;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #6b7280;
      font-weight: 600;
      border-bottom: 2px solid #e5e7eb;
    }
    thead th.right { text-align: right; }
    thead th.center { text-align: center; }
    tbody td {
      padding: 10px 12px;
      border-bottom: 1px solid #f3f4f6;
      font-size: 13px;
    }
    tbody td.right { text-align: right; }
    tbody td.center { text-align: center; }
    .totals {
      display: flex;
      justify-content: flex-end;
      margin-bottom: 24px;
    }
    .totals-table {
      width: 280px;
    }
    .totals-table .row {
      display: flex;
      justify-content: space-between;
      padding: 6px 0;
      font-size: 13px;
    }
    .totals-table .row.total {
      border-top: 2px solid #2563eb;
      margin-top: 8px;
      padding-top: 10px;
      font-size: 18px;
      font-weight: 700;
      color: #2563eb;
    }
    .totals-table .row .label { color: #6b7280; }
    .totals-table .row .value { font-weight: 600; }
    .payment-section {
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 24px;
    }
    .payment-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
    }
    .payment-method {
      flex: 1;
    }
    .payment-method h3 {
      font-size: 14px;
      color: #1e40af;
      margin-bottom: 6px;
    }
    .payment-method p {
      font-size: 12px;
      color: #3b82f6;
      line-height: 1.6;
    }
    .qr-code {
      text-align: center;
    }
    .qr-code img {
      width: 140px;
      height: 140px;
    }
    .qr-code p {
      font-size: 10px;
      color: #6b7280;
      margin-top: 4px;
    }
    .bank-details {
      background: #f0fdf4;
      border: 1px solid #86efac;
      border-radius: 8px;
      padding: 14px 16px;
      margin-bottom: 20px;
    }
    .bank-details h3 {
      font-size: 13px;
      color: #166534;
      margin-bottom: 8px;
    }
    .bank-detail-row {
      display: flex;
      justify-content: space-between;
      padding: 3px 0;
      font-size: 12px;
    }
    .bank-detail-row .label {
      color: #4b5563;
    }
    .bank-detail-row .value {
      font-weight: 600;
      color: #1a1a1a;
      font-family: 'Courier New', monospace;
      letter-spacing: 0.5px;
    }
    .zero-fee-badge {
      display: inline-block;
      background: #dcfce7;
      color: #166534;
      padding: 3px 10px;
      border-radius: 12px;
      font-size: 10px;
      font-weight: 700;
      margin-left: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .footer {
      text-align: center;
      padding-top: 16px;
      border-top: 1px solid #e5e7eb;
    }
    .footer p {
      font-size: 11px;
      color: #9ca3af;
    }
    .notes {
      background: #fefce8;
      border: 1px solid #fde68a;
      border-radius: 6px;
      padding: 10px 14px;
      margin-bottom: 20px;
      font-size: 12px;
      color: #92400e;
    }
    .notes strong { color: #78350f; }
    .due-badge {
      display: inline-block;
      background: #fee2e2;
      color: #dc2626;
      padding: 2px 10px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <div class="invoice-container">
    <!-- Header -->
    <div class="header">
      <div class="brand">
        <h1>{{businessName}}</h1>
        {{#if businessAddress}}<p>{{businessAddress}}</p>{{/if}}
        {{#if businessGstin}}<p>GSTIN: {{businessGstin}}</p>{{/if}}
        <p>📞 {{businessPhone}}</p>
      </div>
      <div class="invoice-title">
        <h2>Invoice</h2>
        <div class="invoice-no">#{{invoiceNo}}</div>
        <div class="date">Date: {{formatDate createdAt}}</div>
        <div class="date">Due: <span class="due-badge">{{formatDate dueDate}}</span></div>
      </div>
    </div>

    <!-- Parties -->
    <div class="parties">
      <div class="party">
        <div class="party-label">From</div>
        <div class="party-name">{{businessName}}</div>
        {{#if businessGstin}}<div class="party-detail">GSTIN: {{businessGstin}}</div>{{/if}}
        <div class="party-detail">📞 {{businessPhone}}</div>
      </div>
      <div class="party">
        <div class="party-label">Bill To</div>
        <div class="party-name">{{clientName}}</div>
        {{#if clientGstin}}<div class="party-detail">GSTIN: {{clientGstin}}</div>{{/if}}
        {{#if clientPhone}}<div class="party-detail">📞 {{clientPhone}}</div>{{/if}}
      </div>
    </div>

    <!-- Line Items -->
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Description</th>
          <th class="center">Qty</th>
          <th class="right">Rate</th>
          <th class="right">Amount</th>
        </tr>
      </thead>
      <tbody>
        {{#each lineItems}}
        <tr>
          <td>{{inc @index}}</td>
          <td>{{this.name}}</td>
          <td class="center">{{this.quantity}}</td>
          <td class="right">{{formatCurrency this.rate}}</td>
          <td class="right">{{formatCurrency this.amount}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- Notes -->
    {{#if notes}}
    <div class="notes">
      <strong>Notes:</strong> {{notes}}
    </div>
    {{/if}}

    <!-- Totals -->
    <div class="totals">
      <div class="totals-table">
        <div class="row">
          <span class="label">Subtotal</span>
          <span class="value">{{formatCurrency subtotal}}</span>
        </div>
        {{#if hasGst}}
        <div class="row">
          <span class="label">GST ({{gstRate}}%)</span>
          <span class="value">{{formatCurrency gstAmount}}</span>
        </div>
        {{/if}}
        <div class="row total">
          <span class="label">Total</span>
          <span class="value">{{formatCurrency totalAmount}}</span>
        </div>
      </div>
    </div>

    <!-- UPI Payment Section (Scan QR / Tap Link) -->
    <div class="payment-section">
      <div class="payment-row">
        <div class="payment-method">
          <h3>💳 Pay via UPI <span class="zero-fee-badge">Zero Fee</span></h3>
          {{#if businessUpiId}}
          <p><strong>UPI ID:</strong> {{businessUpiId}}</p>
          {{/if}}
          <p>Scan the QR code with GPay, PhonePe, Paytm, or any UPI app.</p>
          <p>Amount (₹{{formatCurrency totalAmount}}) is pre-filled — just enter your PIN!</p>
        </div>
        {{#if qrCode}}
        <div class="qr-code">
          <img src="{{qrCode}}" alt="UPI QR Code" />
          <p>Scan to Pay</p>
        </div>
        {{/if}}
      </div>
    </div>

    <!-- Bank Transfer Section (NEFT/IMPS for high-value invoices) -->
    {{#if hasBankDetails}}
    <div class="bank-details">
      <h3>🏦 Bank Transfer (NEFT / IMPS / RTGS)</h3>
      <p style="font-size: 11px; color: #4b5563; margin-bottom: 10px;">For amounts above ₹1,00,000 or if you prefer bank transfer:</p>
      <div class="bank-detail-row">
        <span class="label">Account Name</span>
        <span class="value">{{bankAccountName}}</span>
      </div>
      <div class="bank-detail-row">
        <span class="label">Account No.</span>
        <span class="value">{{bankAccountNo}}</span>
      </div>
      <div class="bank-detail-row">
        <span class="label">IFSC Code</span>
        <span class="value">{{bankIfsc}}</span>
      </div>
      {{#if bankName}}
      <div class="bank-detail-row">
        <span class="label">Bank</span>
        <span class="value">{{bankName}}</span>
      </div>
      {{/if}}
    </div>
    {{/if}}

    <!-- Footer -->
    <div class="footer">
      <p>Generated by BillKaro — WhatsApp-First Invoicing • Zero Transaction Fees</p>
      <p>This is a computer-generated invoice.</p>
    </div>
  </div>
</body>
</html>
